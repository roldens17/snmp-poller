# Frontend -> API
VITE_API_BASE_URL=http://localhost:8081

# Database
POSTGRES_USER=snmp
POSTGRES_PASSWORD=change_me_now
POSTGRES_DB=snmp

# Auth / Session
AUTH_JWT_SECRET=replace_with_long_random_secret
AUTH_ALLOW_REGISTER=false
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_HTTP_ONLY=true
AUTH_COOKIE_SAME_SITE=lax
AUTH_COOKIE_DOMAIN=
AUTH_TOKEN_TTL_HOURS=24

# App modes
DEMO_MODE=false

# Security key (32-byte base64)
# Generate: openssl rand -base64 32
ENCRYPTION_KEY=replace_with_base64_32_byte_key

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

AUTH_LOGIN_RATE_PER_MIN=20
AUTH_LOGIN_BURST=10

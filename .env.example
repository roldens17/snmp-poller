# SNMP Poller Environment Variables
# Copy this file to .env and update with your values

# API Base URL (for frontend)
VITE_API_BASE_URL=http://localhost:8081

# Authentication
# IMPORTANT: Use the same values across all deployments!
AUTH_JWT_SECRET=dev-super-secret-change-me
AUTH_ALLOW_REGISTER=false

# Encryption Key (32 bytes base64-encoded)
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=YcLhDfQcycJN2k5VQBmvrx3y/McF+bVrn4ampNgjGBA=

# Demo Mode (set to false in production)
DEMO_MODE=true

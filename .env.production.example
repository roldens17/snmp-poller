# Domains
APP_DOMAIN=app.example.com
API_DOMAIN=api.example.com

# Frontend
VITE_API_BASE_URL=https://api.example.com

# Database
POSTGRES_USER=snmp
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_DB_PASSWORD
POSTGRES_DB=snmp

# Auth / Session (for cross-subdomain cookies)
AUTH_JWT_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET
AUTH_ALLOW_REGISTER=false
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_HTTP_ONLY=true
AUTH_COOKIE_SAME_SITE=none
AUTH_COOKIE_DOMAIN=.example.com
AUTH_TOKEN_TTL_HOURS=24

# App mode
DEMO_MODE=false

# Security key
ENCRYPTION_KEY=REPLACE_WITH_BASE64_32_BYTE_KEY

# CORS must match app origin exactly
CORS_ALLOWED_ORIGINS=https://app.example.com

AUTH_LOGIN_RATE_PER_MIN=20
AUTH_LOGIN_BURST=10

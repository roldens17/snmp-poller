# =============================
# SNMP SaaS Production Env
# =============================

# Domains
APP_DOMAIN=app.example.com

# Frontend
VITE_API_BASE_URL=/api

# App mode
ENV=production
DEMO_MODE=false

# Postgres (managed recommended)
# Example: postgres://user:pass@host:5432/dbname?sslmode=require
POSTGRES_DSN=postgres://snmp:CHANGE_ME@db-host:5432/snmp?sslmode=require

# Auth / Session
AUTH_JWT_SECRET=CHANGE_ME_LONG_RANDOM_STRING
AUTH_ALLOW_REGISTER=false
AUTH_TOKEN_TTL_HOURS=24

# Cookie settings (cross-subdomain setup)
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_HTTP_ONLY=true
AUTH_COOKIE_SAME_SITE=lax
AUTH_COOKIE_DOMAIN=

# Encryption key (32-byte base64)
# generate: openssl rand -base64 32
ENCRYPTION_KEY=CHANGE_ME_BASE64_32B

# CORS (single-origin default)
CORS_ALLOWED_ORIGINS=https://app.example.com

# Login abuse protection
AUTH_LOGIN_RATE_PER_MIN=20
AUTH_LOGIN_BURST=10

# Optional metrics
METRICS_ENABLED=true
METRICS_PUBLIC=false

# Optional Stripe (for Day 2+)
# STRIPE_SECRET_KEY=sk_live_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# STRIPE_PRICE_STARTER=price_xxx
# STRIPE_PRICE_GROWTH=price_xxx
# STRIPE_PRICE_PRO=price_xxx

# Reverse proxy trust (comma-separated CIDRs/IPs)
HTTP_TRUSTED_PROXIES=127.0.0.1,::1,172.16.0.0/12,10.0.0.0/8,192.168.0.0/16

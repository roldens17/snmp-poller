version: "3.9"

services:
  postgres:
    image: postgres:16
    restart: unless-stopped
    environment:
      POSTGRES_DB: snmp
      POSTGRES_USER: snmp
      POSTGRES_PASSWORD: snmp
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U snmp -d snmp"]
      interval: 5s
      timeout: 5s
      retries: 5
    ports:
      - "5432:5432"
    volumes:
      - postgres-data:/var/lib/postgresql/data

  snmp-poller:
    build:
      context: .
      dockerfile: Dockerfile
    depends_on:
      postgres:
        condition: service_healthy
    restart: unless-stopped
    env_file:
      - .env.example
    ports:
      - "8080:8080"
      - "9105:9105"
    volumes:
      - ./config.example.yaml:/app/config.yaml:ro

volumes:
  postgres-data: {}
